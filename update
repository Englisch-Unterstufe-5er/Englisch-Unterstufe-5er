  funMemState.cards[i].flipped=true;funMemState.flipped.push(i);renderFunMem();
  if(funMemState.flipped.length===2){
    funMemState.lock=true;funMemState.moves++;
    const[a,b]=funMemState.flipped;
    if(funMemState.cards[a].pair===funMemState.cards[b].pair){funMemState.cards[a].matched=funMemState.cards[b].matched=true;funMemState.matched++;funMemState.flipped=[];funMemState.lock=false;renderFunMem();if(funMemState.matched===8){addStar();}}
    else setTimeout(()=>{funMemState.cards[a].flipped=funMemState.cards[b].flipped=false;funMemState.flipped=[];funMemState.lock=false;renderFunMem();},900);
  }
}

// Reaction
let reactState={waiting:false,t:0};
function reactClick() {
  if(!reactState.waiting){document.getElementById('reactBox').style.background='#E74C3C';document.getElementById('reactBox').textContent='Warte...';const delay=1000+Math.random()*3000;setTimeout(()=>{reactState.waiting=true;reactState.t=Date.now();document.getElementById('reactBox').style.background='#27AE60';document.getElementById('reactBox').textContent='JETZT!';},delay);}
  else{const ms=Date.now()-reactState.t;reactState.waiting=false;document.getElementById('reactResult').textContent=ms+'ms – '+(ms<300?'⚡ Blitzschnell!':ms<500?'👍 Gut!':'🐢 Zu langsam!');document.getElementById('reactBox').style.background='var(--card)';document.getElementById('reactBox').textContent='Nochmal klicken';if(ms<400)addStar();}
}

// Clicker
let clickState={count:0,active:false};
function startClicker() {
  clickState={count:0,active:true};document.getElementById('clickScore').textContent='0';
  let t=10;document.getElementById('clickTimer').textContent=t;
  const ti=setInterval(()=>{t--;document.getElementById('clickTimer').textContent=t;if(t<=0){clearInterval(ti);clickState.active=false;const bonus=Math.floor(clickState.count/10);for(let i=0;i<bonus;i++)addStar();alert('Zeit! '+clickState.count+' Klicks! +'+bonus+'⭐');}},1000);
}
function clickerClick() {if(clickState.active){clickState.count++;document.getElementById('clickScore').textContent=clickState.count;}}

// Jump
let jumpState={};
function startJump() {
  const canvas=document.getElementById('jump-canvas');
  const ctx=canvas.getContext('2d');
  jumpState={y:160,vy:0,score:0,obstacles:[],active:true,frame:0};
  document.getElementById('jumpScore').textContent='0';
  canvas.onclick=()=>{if(jumpState.y>=150)jumpState.vy=-12;};
  if(jumpState.loop)cancelAnimationFrame(jumpState.loop);
  function frame(){
    if(!jumpState.active)return;
    jumpState.vy+=0.8;jumpState.y+=jumpState.vy;
    if(jumpState.y>160){jumpState.y=160;jumpState.vy=0;}
    jumpState.frame++;
    if(jumpState.frame%60===0){jumpState.obstacles.push({x:300,h:20+Math.random()*40});}
    jumpState.obstacles=jumpState.obstacles.filter(o=>o.x>-10);
    jumpState.obstacles.forEach(o=>o.x-=4);
    ctx.clearRect(0,0,300,200);
    ctx.fillStyle='var(--accent)';ctx.fillRect(10,jumpState.y-20,20,20);
    ctx.fillStyle='#E74C3C';
    jumpState.obstacles.forEach(o=>{ctx.fillRect(o.x,200-o.h,20,o.h);if(o.x<30&&o.x>-10&&jumpState.y>200-o.h-20){jumpState.active=false;alert('Game Over! Score: '+jumpState.score);return;}});
    if(jumpState.frame%30===0){jumpState.score++;document.getElementById('jumpScore').textContent=jumpState.score;if(jumpState.score%10===0)addStar();}
    jumpState.loop=requestAnimationFrame(frame);
  }
  jumpState.loop=requestAnimationFrame(frame);
}

