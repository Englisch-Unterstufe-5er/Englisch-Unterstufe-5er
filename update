// Snake
let snake={}, snakeLoop=null;
function startSnake() {
  snake = {x:140,y:140,dx:20,dy:0,body:[{x:140,y:140}],food:{x:60,y:60},score:0,alive:true};
  document.getElementById('snakeScore').textContent='0';
  if(snakeLoop) clearInterval(snakeLoop);
  snakeLoop = setInterval(tickSnake,200);
}
function dir(d) {
  if(d==='up'&&snake.dy===0){snake.dx=0;snake.dy=-20;}
  if(d==='down'&&snake.dy===0){snake.dx=0;snake.dy=20;}
  if(d==='left'&&snake.dx===0){snake.dx=-20;snake.dy=0;}
  if(d==='right'&&snake.dx===0){snake.dx=20;snake.dy=0;}
}
function tickSnake() {
  if(!snake.alive) return;
  snake.x+=snake.dx; snake.y+=snake.dy;
  if(snake.x<0||snake.x>=280||snake.y<0||snake.y>=280){snake.alive=false;clearInterval(snakeLoop);alert('Game Over! Score: '+snake.score);return;}
  snake.body.unshift({x:snake.x,y:snake.y});
  if(snake.x===snake.food.x&&snake.y===snake.food.y){
    snake.score+=10; document.getElementById('snakeScore').textContent=snake.score;
    snake.food={x:Math.floor(Math.random()*14)*20,y:Math.floor(Math.random()*14)*20};
    addStar();
  } else snake.body.pop();
  const c=document.getElementById('snake-canvas').getContext('2d');
  c.fillStyle='#fff'; c.fillRect(0,0,280,280);
  c.fillStyle='#4A90D9'; snake.body.forEach(s=>c.fillRect(s.x,s.y,18,18));
  c.fillStyle='#E74C3C'; c.fillRect(snake.food.x,snake.food.y,18,18);
}

