// Build the vocab list UI with chapter group headers and checkboxes
function renderLernplanVocabList() {
  const container = document.getElementById('lernplanVocabList');
  let html = '';
  lernplanSourceChapters.forEach(chapId => {
    const ch = greenLine1[chapId];
    if (!ch) return;
    html += `<div class="lp-group-header">${ch.icon} ${ch.title} <span style="font-weight:normal;opacity:0.7;">(${ch.vocab.length})</span></div>`;
    ch.vocab.forEach((v, idx) => {
      const key = chapId + '::' + idx;
      const checked = lernplanSelected.has(key);
      html += `<div class="lp-vocab-row" onclick="toggleLernplanVocab('${key}', this)">
        <div class="lp-vocab-check ${checked ? 'checked' : ''}">${checked ? '✓' : ''}</div>
        <div class="lp-vocab-de">${v.de}</div>
        <div class="lp-vocab-en">${v.en}</div>
      </div>`;
    });
  });
  container.innerHTML = html;
  updateLernplanCount();
}

function toggleLernplanVocab(key, row) {
  const check = row.querySelector('.lp-vocab-check');
  if (lernplanSelected.has(key)) {
    lernplanSelected.delete(key);
    check.classList.remove('checked');
    check.textContent = '';
  } else {
    lernplanSelected.add(key);
    check.classList.add('checked');
    check.textContent = '✓';
  }
  updateLernplanCount();
}

function updateLernplanCount() {
  const n = lernplanSelected.size;
  document.getElementById('lernplanCountBadge').textContent = n + ' ausgewählt';
}

function lernplanSelectAll() {
  lernplanSourceChapters.forEach(chapId => {
    const ch = greenLine1[chapId];
    if (!ch) return;
    ch.vocab.forEach((v, idx) => lernplanSelected.add(chapId + '::' + idx));
  });
  renderLernplanVocabList();
}

function lernplanSelectNone() {
  lernplanSelected.clear();
  renderLernplanVocabList();
}

// Get resolved vocab array from selected keys
function getSelectedVocab() {
  const result = [];
  lernplanSelected.forEach(key => {
    const [chapId, idx] = key.split('::');
    const ch = greenLine1[chapId];
    if (ch && ch.vocab[parseInt(idx)]) result.push(ch.vocab[parseInt(idx)]);
  });
  return result;
}

// Start directly without saving
function startLernplanDirect(mode) {
  const selected = getSelectedVocab();
  if (selected.length < 2) { alert('Bitte mindestens 2 Vokabeln auswählen!'); return; }
  vocab['lp_temp'] = selected;
  currentCat = 'lp_temp';
  if (mode === 'flash') startFlash();
  else if (mode === 'choice') startQuiz();
  else if (mode === 'write') startWriteQuiz();
}

// Save plan to localStorage
function saveLernplan() {
  const selected = getSelectedVocab();
  if (selected.length < 2) { alert('Mindestens 2 Vokabeln auswählen!'); return; }
  const name = document.getElementById('lernplanNameInput').value.trim() || ('Lernplan ' + (data.lernplaene ? data.lernplaene.length + 1 : 1));
  if (!data.lernplaene) data.lernplaene = [];
  const editId = window._lernplanEditId;
  if (editId !== null && editId !== undefined) {
    data.lernplaene[editId] = { name, keys: [...lernplanSelected], vocab: selected, created: Date.now() };
  } else {
    data.lernplaene.push({ name, keys: [...lernplanSelected], vocab: selected, created: Date.now() });
  }
  saveData();
  renderLernplaeneCountHint();
  alert('✅ Lernplan "' + name + '" gespeichert!');
  showScreen('lernplaene');
  renderLernplaene();
}

function renderLernplaene() {
