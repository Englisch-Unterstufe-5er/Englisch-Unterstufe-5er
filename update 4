let memState = { cards:[], flipped:[], matched:0, moves:0, lock:false };

function startMemory() {
  const v = currentCat === 'mix' ? window.mixVocabTemp : (vocab[currentCat] || vocab.tiere);
  const selected = [...v].sort(() => Math.random()-0.5).slice(0,8);
  const pairs = [...selected.map((w,i) => ({id:i,text:w.de,pair:i})), ...selected.map((w,i) => ({id:i+8,text:w.en,pair:i}))];
  memState = { cards: pairs.sort(() => Math.random()-0.5), flipped: [], matched: 0, moves: 0, lock: false };
  renderMemory();
  showScreen('memory');
}

function renderMemory() {
  document.getElementById('memMoves').textContent = memState.moves;
  document.getElementById('memPairs').textContent = memState.matched;
  document.getElementById('memGrid').innerHTML = memState.cards.map((c,i) =>
    '<div class="mem-card" onclick="flipMemCard('+i+')" id="mc'+i+'">' + (c.flipped || c.matched ? c.text : '?') + '</div>'
  ).join('');
}

function flipMemCard(i) {
  if (memState.lock || memState.cards[i].flipped || memState.cards[i].matched) return;
  memState.cards[i].flipped = true;
  memState.flipped.push(i);
  document.getElementById('mc'+i).textContent = memState.cards[i].text;
  document.getElementById('mc'+i).classList.add('flipped');
  if (memState.flipped.length === 2) {
    memState.lock = true; memState.moves++;
    document.getElementById('memMoves').textContent = memState.moves;
    const [a, b] = memState.flipped;
    if (memState.cards[a].pair === memState.cards[b].pair) {
      memState.cards[a].matched = memState.cards[b].matched = true;
      document.getElementById('mc'+a).classList.add('matched');
      document.getElementById('mc'+b).classList.add('matched');
      memState.matched++; document.getElementById('memPairs').textContent = memState.matched;
      memState.flipped = []; memState.lock = false;
      if (memState.matched === 8) { addStar(); alert('🎉 Fertig in '+memState.moves+' Zügen!'); }
    } else {
      setTimeout(() => {
        memState.cards[a].flipped = memState.cards[b].flipped = false;
        document.getElementById('mc'+a).textContent = '?'; document.getElementById('mc'+a).classList.remove('flipped');
        document.getElementById('mc'+b).textContent = '?'; document.getElementById('mc'+b).classList.remove('flipped');
        memState.flipped = []; memState.lock = false;
      }, 1000);
    }
  }
}

