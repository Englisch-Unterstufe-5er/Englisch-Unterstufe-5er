// Snake
let snake={}, snakeLoop=null;
function startSnake() {
  snake = {x:140,y:140,dx:20,dy:0,body:[{x:140,y:140}],food:{x:60,y:60},score:0,alive:true};
  document.getElementById('snakeScore').textContent='0';
  if(snakeLoop) clearInterval(snakeLoop);
  snakeLoop = setInterval(tickSnake,200);
}
function dir(d) {
  if(d==='up'&&snake.dy===0){snake.dx=0;snake.dy=-20;}
  if(d==='down'&&snake.dy===0){snake.dx=0;snake.dy=20;}
  if(d==='left'&&snake.dx===0){snake.dx=-20;snake.dy=0;}
  if(d==='right'&&snake.dx===0){snake.dx=20;snake.dy=0;}
}
function tickSnake() {
  if(!snake.alive) return;
  snake.x+=snake.dx; snake.y+=snake.dy;
  if(snake.x<0||snake.x>=280||snake.y<0||snake.y>=280){snake.alive=false;clearInterval(snakeLoop);alert('Game Over! Score: '+snake.score);return;}
  snake.body.unshift({x:snake.x,y:snake.y});
  if(snake.x===snake.food.x&&snake.y===snake.food.y){
    snake.score+=10; document.getElementById('snakeScore').textContent=snake.score;
    snake.food={x:Math.floor(Math.random()*14)*20,y:Math.floor(Math.random()*14)*20};
    addStar();
  } else snake.body.pop();
  const c=document.getElementById('snake-canvas').getContext('2d');
  c.fillStyle='#fff'; c.fillRect(0,0,280,280);
  c.fillStyle='#4A90D9'; snake.body.forEach(s=>c.fillRect(s.x,s.y,18,18));
  c.fillStyle='#E74C3C'; c.fillRect(snake.food.x,snake.food.y,18,18);
}

// Catch game
let catchState={};
function startCatch() {
  catchState={score:0,time:30,active:true};
  document.getElementById('catchScore').textContent='0';
  clearInterval(catchState.dropInt); clearInterval(catchState.timer);
  catchState.dropInt=setInterval(dropItem,1000);
  catchState.timer=setInterval(()=>{catchState.time--;document.getElementById('catchTime').textContent=catchState.time;if(catchState.time<=0){clearInterval(catchState.dropInt);clearInterval(catchState.timer);catchState.active=false;alert('Zeit! Score: '+catchState.score);}},1000);
  const area=document.getElementById('catchArea');
  area.ontouchmove=e=>{e.preventDefault();const r=area.getBoundingClientRect();const x=e.touches[0].clientX-r.left;document.getElementById('catchBasket').style.left=Math.max(0,Math.min(260,x-20))+'px';};
  area.onmousemove=e=>{const r=area.getBoundingClientRect();document.getElementById('catchBasket').style.left=Math.max(0,Math.min(260,e.clientX-r.left-20))+'px';};
}
function dropItem() {
  if(!catchState.active) return;
  const area=document.getElementById('catchArea');
  const item=document.createElement('div');
  item.style.cssText='position:absolute;font-size:1.8rem;top:0;left:'+Math.random()*260+'px;transition:top 2s linear';
  item.textContent=['🍎','⭐','💎','🎯'][Math.floor(Math.random()*4)];
  area.appendChild(item);
  requestAnimationFrame(()=>{item.style.top='320px';});
  item.addEventListener('transitionend',()=>{
    const bx=parseInt(document.getElementById('catchBasket').style.left)||130;
    const ix=parseInt(item.style.left);
    if(Math.abs(ix-bx)<50){catchState.score+=10;document.getElementById('catchScore').textContent=catchState.score;addStar();}
    item.remove();
  });
}

// Fun Memory
let funMemState={cards:[],flipped:[],matched:0,moves:0,lock:false};
const memEmojis=['🐶','🐱','🐸','🦊','🐼','🐧','🦉','🐰'];
function startFunMem() {
  const pairs=[...memEmojis,...memEmojis].sort(()=>Math.random()-0.5).map((e,i)=>({id:i,text:e,pair:memEmojis.indexOf(e),flipped:false,matched:false}));
  funMemState={cards:pairs,flipped:[],matched:0,moves:0,lock:false};
  renderFunMem();
}
function renderFunMem() {
  document.getElementById('funMemMoves').textContent=funMemState.moves;
  document.getElementById('funMemGrid').innerHTML=funMemState.cards.map((c,i)=>'<div class="mem-card'+(c.flipped?' flipped':'')+(c.matched?' matched':'')+'" onclick="flipFunMem('+i+')">'+(c.flipped||c.matched?c.text:'?')+'</div>').join('');
}
function flipFunMem(i) {
  if(funMemState.lock||funMemState.cards[i].flipped||funMemState.cards[i].matched)return;
  funMemState.cards[i].flipped=true;funMemState.flipped.push(i);renderFunMem();
  if(funMemState.flipped.length===2){
    funMemState.lock=true;funMemState.moves++;
    const[a,b]=funMemState.flipped;
    if(funMemState.cards[a].pair===funMemState.cards[b].pair){funMemState.cards[a].matched=funMemState.cards[b].matched=true;funMemState.matched++;funMemState.flipped=[];funMemState.lock=false;renderFunMem();if(funMemState.matched===8){addStar();}}
    else setTimeout(()=>{funMemState.cards[a].flipped=funMemState.cards[b].flipped=false;funMemState.flipped=[];funMemState.lock=false;renderFunMem();},900);
  }
}

// Reaction
let reactState={waiting:false,t:0};
function reactClick() {
  if(!reactState.waiting){document.getElementById('reactBox').style.background='#E74C3C';document.getElementById('reactBox').textContent='Warte...';const delay=1000+Math.random()*3000;setTimeout(()=>{reactState.waiting=true;reactState.t=Date.now();document.getElementById('reactBox').style.background='#27AE60';document.getElementById('reactBox').textContent='JETZT!';},delay);}
  else{const ms=Date.now()-reactState.t;reactState.waiting=false;document.getElementById('reactResult').textContent=ms+'ms – '+(ms<300?'⚡ Blitzschnell!':ms<500?'👍 Gut!':'🐢 Zu langsam!');document.getElementById('reactBox').style.background='var(--card)';document.getElementById('reactBox').textContent='Nochmal klicken';if(ms<400)addStar();}
}

