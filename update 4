function addWord(w) { sentState.selected.push(w); renderSentence(); }
function removeWord(w) { sentState.selected.splice(sentState.selected.lastIndexOf(w),1); renderSentence(); }
function clearSent() { sentState.selected = []; renderSentence(); }

function checkSent() {
  const ans = sentState.selected.join(' ');
  if (ans === sentState.current.answer) { alert('✅ Richtig!'); addStar(); startSentence(); }
  else alert('❌ Nochmal versuchen!');
}

