// Feste Grammatik-Aufgaben (Typ A: Multiple Choice)
const diagGrammarQs = [
  { type:'choice', badge:'✏️ Grammatik', instruction:'Wähle die richtige Antwort:', word:'I ___ a student.', correct:'am', opts:['am','is','are','be'] },
  { type:'choice', badge:'✏️ Grammatik', instruction:'Wähle die richtige Antwort:', word:'She ___ a dog.', correct:'has', opts:['have','has','had','is'] },
  { type:'choice', badge:'✏️ Grammatik', instruction:'Wähle die richtige Antwort:', word:'They ___ happy.', correct:'are', opts:['am','is','are','be'] },
  { type:'choice', badge:'✏️ Grammatik', instruction:'Fülle die Lücke: ___ apple.', correct:'an', opts:['a','an','the','–'] },
];

// Feste Satz-Baustein-Aufgaben (Typ C)
// words = korrekte Reihenfolge; shuffledWords wird beim Start zufällig gemischt
const diagSentenceQs = [
  { type:'sentence', badge:'🔧 Sätze bauen', instruction:'Bringe die Wörter in die richtige Reihenfolge!',
    words:['I','am','from','Germany','.'], answer:'I am from Germany .' },
  { type:'sentence', badge:'🔧 Sätze bauen', instruction:'Bringe die Wörter in die richtige Reihenfolge!',
    words:['She','has','a','book','.'], answer:'She has a book .' },
  { type:'sentence', badge:'🔧 Sätze bauen', instruction:'Bringe die Wörter in die richtige Reihenfolge!',
    words:['He','plays','football','.'], answer:'He plays football .' },
];

// Bild-Aufgaben (Typ B: Emoji sehen → englisches Wort schreiben), nur aus nicht-GL1-Vokabeln
const diagImageQs = [
  { type:'image', badge:'🖼️ Bilder-Quiz', instruction:'Was siehst du? Schreibe das englische Wort!', emoji:'🍎', correct:'apple' },
  { type:'image', badge:'🖼️ Bilder-Quiz', instruction:'Was siehst du? Schreibe das englische Wort!', emoji:'🐦', correct:'bird' },
  { type:'image', badge:'🖼️ Bilder-Quiz', instruction:'Was siehst du? Schreibe das englische Wort!', emoji:'👩', correct:'mother' },
];

// Satz-Builder State für den Eignungstest
let diagSentSelected = [];
let diagSentCurrent = null;
let diagSentLocked = false;

function startDiagTest() {
  // 5 zufällige Vokabel-Multiple-Choice aus nicht-GL1-Bereich
  const allVocab = [...vocab.tiere, ...vocab.farben, ...vocab.zahlen, ...vocab.familie, ...vocab.schule, ...vocab.essen];
  const allDe = allVocab.map(x => x.de);
  const shuffledVocab = [...allVocab].sort(() => Math.random()-0.5).slice(0, 5);
  const vocabQs = shuffledVocab.map(w => ({
    type: 'choice',
    badge: '📝 Vokabeln',
    instruction: 'Was heißt auf Deutsch...',
    word: w.en,
    correct: w.de,
    opts: getOpts(w.de, allDe)
  }));

  // Grammatik zufällig gemischt (4 Fragen)
  const gramQs = [...diagGrammarQs].sort(() => Math.random()-0.5);

  // Satz-Bausteine gemischt (3 Fragen)
  const sentQs = [...diagSentenceQs].sort(() => Math.random()-0.5);

  // Bild-Fragen gemischt (3 Fragen)
  const imgQs = [...diagImageQs].sort(() => Math.random()-0.5);

  // Alle 15 Fragen zusammenführen und mischen (außer Satz+Bild bleiben erkennbar)
  const allQs = [...vocabQs, ...gramQs, ...imgQs, ...sentQs];
  // Leicht mischen, aber nicht zu chaotisch (Typen bleiben verstreut)
  diagTest = { questions: allQs.sort(() => Math.random()-0.5), i: 0, c: 0 };
  goStep(4);
  showDiagQ();
}

function getOpts(correct, all) {
  const others = [...new Set(all)].filter(o => o !== correct).sort(() => Math.random()-0.5).slice(0,3);
  return [correct, ...others].sort(() => Math.random()-0.5);
}

function showDiagQ() {
  const q = diagTest.questions[diagTest.i];
  const total = diagTest.questions.length;
  document.getElementById('testProg').textContent = 'Frage '+(diagTest.i+1)+'/'+total;
  document.getElementById('testScore').textContent = '✓ '+diagTest.c;
  document.getElementById('testBarFill').style.width = ((diagTest.i+1)/total*100)+'%';
  document.getElementById('testTypeBadge').textContent = q.badge;
  document.getElementById('testInstruction').textContent = q.instruction;

  // Reset alle Bereiche
  document.getElementById('testWord').style.display = 'block';
  document.getElementById('testOpts').style.display = 'grid';
  document.getElementById('testImgArea').style.display = 'none';
  document.getElementById('testSentArea').style.display = 'none';
  document.getElementById('testOpts').innerHTML = '';
  document.getElementById('testImgFeedback').textContent = '';
  document.getElementById('testSentFeedback').textContent = '';

  if (q.type === 'choice') {
    document.getElementById('testWord').textContent = q.word;
    document.getElementById('testOpts').innerHTML = q.opts.map(o =>
      '<button class="test-opt" onclick="checkDiagQ(this,\''+o.replace(/'/g,"\\'")+'\')">'+o+'</button>'
    ).join('');

  } else if (q.type === 'image') {
    document.getElementById('testWord').textContent = q.emoji;
    document.getElementById('testWord').style.fontSize = '3.5rem';
    document.getElementById('testOpts').style.display = 'none';
    document.getElementById('testImgArea').style.display = 'block';
    document.getElementById('testImgInput').value = '';
    document.getElementById('testImgInput').disabled = false;
    document.getElementById('testImgInput').style.borderColor = '';

  } else if (q.type === 'sentence') {
    document.getElementById('testWord').style.display = 'none';
    document.getElementById('testOpts').style.display = 'none';
    document.getElementById('testSentArea').style.display = 'block';
    diagSentCurrent = q;
    // Bausteine einmalig zufällig mischen und am Objekt speichern
    diagSentCurrent._shuffled = [...q.words].sort(() => Math.random()-0.5);
    diagSentSelected = [];
    diagSentLocked = false;
    renderDiagSent();
  }
}

// Typ A: Multiple Choice
function checkDiagQ(btn, ans) {
  const q = diagTest.questions[diagTest.i];
  document.querySelectorAll('.test-opt').forEach(b => {
    b.disabled = true;
    if (b.textContent === q.correct) b.classList.add('correct');
  });
  if (ans === q.correct) { btn.classList.add('correct'); diagTest.c++; document.getElementById('testScore').textContent = '✓ '+diagTest.c; }
  else btn.classList.add('wrong');
  setTimeout(nextDiagQ, 1100);
}

// Typ B: Bild + Schreiben
function checkDiagImgQ() {
  const q = diagTest.questions[diagTest.i];
  const ans = document.getElementById('testImgInput').value.trim().toLowerCase();
  const correct = ans === q.correct.toLowerCase();
  const fb = document.getElementById('testImgFeedback');
  document.getElementById('testImgInput').disabled = true;
  if (correct) {
    fb.textContent = '✓ Richtig!'; fb.style.color = '#a8ffb0';
    diagTest.c++; document.getElementById('testScore').textContent = '✓ '+diagTest.c;
  } else {
    fb.textContent = '✗ Richtig wäre: ' + q.correct; fb.style.color = '#ffaaaa';
  }
  setTimeout(nextDiagQ, 1300);
}

// Typ C: Satz-Baustein
function renderDiagSent() {
  document.getElementById('testSentResult').innerHTML = diagSentSelected.map((w,i) =>
    '<span onclick="removeDiagWord('+i+')" style="padding:6px 12px;background:rgba(255,255,255,0.3);border-radius:8px;cursor:pointer;font-size:0.95rem;color:white;">'+w+'</span>'
  ).join('');
  // Verbleibende Wörter aus der gemischten Reihenfolge berechnen
  const used = {};
  diagSentSelected.forEach(w => { used[w] = (used[w]||0)+1; });
  const rem = [];
  // Gemischte Reihenfolge beibehalten (nicht die Original-Reihenfolge!)
  diagSentCurrent._shuffled.forEach(w => {
    const need = diagSentCurrent._shuffled.filter(x=>x===w).length;
    const have = used[w]||0;
    if (rem.filter(x=>x===w).length < need - have) rem.push(w);
  });
  document.getElementById('testSentBank').innerHTML = rem.map(w =>
    '<span onclick="addDiagWord(\''+w.replace(/'/g,"\\'")+'\''+')" style="padding:8px 14px;background:rgba(255,255,255,0.2);border:2px solid rgba(255,255,255,0.5);border-radius:8px;cursor:pointer;font-size:0.95rem;color:white;">'+w+'</span>'
  ).join('');
}

function addDiagWord(w) {
  if (diagSentLocked) return;
  diagSentSelected.push(w);
  renderDiagSent();
}

function removeDiagWord(i) {
  if (diagSentLocked) return;
  diagSentSelected.splice(i, 1);
  renderDiagSent();
}

function clearDiagSent() {
  if (diagSentLocked) return;
  diagSentSelected = [];
  renderDiagSent();
}

function checkDiagSent() {
  if (diagSentLocked) return;
  diagSentLocked = true;
  const ans = diagSentSelected.join(' ');
  const fb = document.getElementById('testSentFeedback');
  if (ans === diagSentCurrent.answer) {
    fb.textContent = '✓ Richtig!'; fb.style.color = '#a8ffb0';
    diagTest.c++; document.getElementById('testScore').textContent = '✓ '+diagTest.c;
  } else {
    fb.textContent = '✗ Richtig: ' + diagSentCurrent.answer; fb.style.color = '#ffaaaa';
  }
  setTimeout(nextDiagQ, 1500);
}

function nextDiagQ() {
  diagTest.i++;
  if (diagTest.i >= diagTest.questions.length) finishDiagTest();
  else showDiagQ();
}

function finishDiagTest() {
  const score = diagTest.c;
  const total = diagTest.questions.length;
  const pct = Math.round(score/total*100);
  if (pct >= 80) {
    data.level = 'Fortgeschritten';
    document.getElementById('resultEmoji').textContent = '🏆';
    document.getElementById('resultTitle').textContent = 'Wow, ausgezeichnet!';
    document.getElementById('levelText').textContent = '🏆 Fortgeschritten';
  } else if (pct >= 53) {
    data.level = 'Mittel';
    document.getElementById('resultEmoji').textContent = '⭐';
    document.getElementById('resultTitle').textContent = 'Gut gemacht!';
    document.getElementById('levelText').textContent = '⭐ Mittel';
  } else {
    data.level = 'Anfänger';
    document.getElementById('resultEmoji').textContent = '🌱';
    document.getElementById('resultTitle').textContent = 'Guter Start!';
    document.getElementById('levelText').textContent = '🌱 Anfänger';
  }
  document.getElementById('resultMessage').textContent = score+'/'+total+' richtig ('+pct+'%)';
  goStep(5);
}

